# Copilot API Environment Configuration
# Copy this file to .env and modify as needed

# Trace folder for logging LLM requests and responses
# Used when --trace flag is enabled
# Default: ./traces (current working directory)
TRACE_OUTPUT_FOLDER=./traces

# Idle timeout in seconds for the Bun server
# Default: 255 seconds
IDLE_TIMEOUT=255

# Model mappings to redirect requests from one model to another
# Format: "source1:target1,source2:target2"
# Example: "claude-sonnet-4-20250514:claude-opus-4,gpt-4:gpt-4-turbo"
# MODEL_MAPPINGS="claude-sonnet-4-5-20250929:claude-sonnet-4.5,claude-opus-4-5-20251101:claude-opus-4.5,claude-haiku-4-5-20251001:claude-haiku-4.5"
# MODEL_MAPPINGS="claude-opus-4-6:claude-opus-4.6,claude-sonnet-4-5:claude-sonnet-4.5,claude-sonnet-4-6:claude-sonnet-4.6,claude-opus-4-5:claude-opus-4.5,claude-haiku-4-5:claude-haiku-4.5"
# MODEL_MAPPINGS="claude-opus-4-6:claude-opus-4.6-fast,claude-sonnet-4-5:claude-sonnet-4.5,claude-sonnet-4-6:claude-sonnet-4.6,claude-opus-4-5:claude-opus-4.5,claude-haiku-4-5:claude-haiku-4.5"
MODEL_MAPPINGS="claude-opus-4-7:claude-opus-4.7-1m-internal,claude-opus-4-6:claude-opus-4.6-1m,claude-sonnet-4-6:claude-sonnet-4.6,claude-sonnet-4-5:claude-sonnet-4.5,claude-opus-4-5:claude-opus-4.5,claude-haiku-4-5:claude-haiku-4.5"
# MODEL_MAPPINGS="claude-opus-4-6:claude-opus-4.6-1m,claude-sonnet-4-6:claude-sonnet-4.6,claude-haiku-4-5:claude-haiku-4.5"

# Port of the Copilot Token Bridge VS Code extension (http://127.0.0.1:<port>/token)
# Default: 18774
# VSCODE_PROXY_PORT=18774
